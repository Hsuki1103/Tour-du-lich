# Vào thư mục backend
cd backend

# Tạo file .gitignore
cat > .gitignore << 'EOF'
# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.local
.env.production

# Build outputs
dist/
build/
out/

# Database
*.sqlite
*.db
*.sqlite3

# Logs
logs/
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Testing
coverage/
.nyc_output/

# Uploads
uploads/
public/uploads/
storage/

# Temporary files
tmp/
temp/
EOF